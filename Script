local MaxLevelValue = 2800  -- Level cap updated to 2800

local dataSuccess, dataErr = pcall(function()
    local dataFolder = Player:FindFirstChild("Data") or Player:WaitForChild("Data", 5)
    if dataFolder then
        local levelObj = dataFolder:FindFirstChild("Level") or dataFolder:WaitForChild("Level", 5)
        if levelObj then
            PlayerLevelValue = levelObj.Value
        end
    end
end)

-- Dynamic Sea Detection
local Sea1, Sea2, Sea3 = false, false, false
