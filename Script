    if PlayerLevelValue >= 1500 then
        Sea3 = true
    elseif PlayerLevelValue >= 700 then
        Sea2 = true
    else
        Sea1 = true
    end
else
    -- Fallback default if data check fails, ensuring tabs populate anyway
    Sea3 = true
end

